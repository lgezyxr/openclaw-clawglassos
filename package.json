{
  "name": "openclaw-clawglassos",
  "version": "0.1.2",
  "description": "Community OpenClaw channel plugin for ClawGlassOS — bridges Even Realities G2 smart glasses (via the ClawGlassOS WebView) to the OpenClaw gateway.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/openclaw-clawglassos"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "clawglassos",
      "label": "ClawGlassOS (Even G2)",
      "blurb": "Bridges Even Realities G2 smart glasses (via the ClawGlassOS WebView) to OpenClaw as a chat channel."
    },
    "install": {
      "npmSpec": "openclaw-clawglassos",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.21"
    },
    "compat": {
      "pluginApi": ">=2026.5.21"
    },
    "build": {
      "openclawVersion": "2026.5.21"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.21"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "dependencies": {
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/ws": "^8.5.10",
    "openclaw": ">=2026.5.21",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0"
  }
}
