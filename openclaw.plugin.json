{
  "id": "clawglassos",
  "kind": "channel",
  "channels": ["clawglassos"],
  "name": "ClawGlassOS (Even G2)",
  "description": "Community plugin: bridges Even Realities G2 smart glasses (via the ClawGlassOS WebView) to OpenClaw as a chat channel.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "channelConfigs": {
    "clawglassos": {
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["token"],
        "properties": {
          "token": {
            "type": "string",
            "description": "Shared secret the WebView must present in the `?token=` query string when opening the WebSocket."
          },
          "host": {
            "type": "string",
            "default": "0.0.0.0",
            "description": "Network interface to bind the WebSocket server to."
          },
          "port": {
            "type": "integer",
            "default": 8787,
            "minimum": 1,
            "maximum": 65535
          },
          "path": {
            "type": "string",
            "default": "/ws"
          },
          "allowFrom": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "Stable identity allowlist for DMs. Each entry is a device ID (returned by the WebView in its `hello` frame)."
          },
          "dmPolicy": {
            "type": "string",
            "enum": ["open", "allowlist", "pairing", "disabled"],
            "default": "allowlist",
            "description": "Who can DM the bot. `open` admits everyone; `allowlist` requires the deviceId in `allowFrom`; `pairing` runs the SDK pairing handshake; `disabled` rejects all DMs."
          },
          "dmSecurity": {
            "type": "string",
            "enum": ["open", "allowlist", "pairing", "disabled"],
            "description": "Deprecated alias for `dmPolicy`. Kept for back-compat with 0.1.x configs; new configs should use `dmPolicy` directly."
          },
          "stt": {
            "type": "object",
            "additionalProperties": false,
            "description": "Server-side speech-to-text. When omitted the plugin emits stub transcripts (useful for the WebView-side STT path).",
            "properties": {
              "provider": {
                "type": "string",
                "enum": ["stub", "azureWhisper"],
                "default": "stub"
              },
              "azure": {
                "type": "object",
                "additionalProperties": false,
                "description": "Required when provider = azureWhisper.",
                "properties": {
                  "endpoint": { "type": "string" },
                  "apiKey": { "type": "string" },
                  "deployment": { "type": "string" },
                  "apiVersion": { "type": "string", "default": "2024-06-01" },
                  "language": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "uiHints": {
        "token": {
          "label": "Shared token",
          "sensitive": true
        },
        "port": { "label": "WebSocket port" },
        "path": { "label": "WebSocket path" },
        "dmPolicy": { "label": "DM policy" },
        "stt.azure.apiKey": { "sensitive": true }
      }
    }
  }
}
